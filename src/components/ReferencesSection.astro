---
import { references } from '../content/site';
---

<section id="referenzen" class="scroll-mt-24 bg-fog-50 py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="flex flex-wrap items-end justify-between gap-6">
      <h1 class="text-balance break-words font-display text-3xl font-bold leading-tight text-navy-800 sm:text-4xl">
        Referenzen
      </h1>
      <p class="max-w-sm text-sm leading-relaxed text-slate-600">
        Eine Auswahl realisierter Silo- und Soleanlagen für den kommunalen Winterdienst.
      </p>
    </div>

    <div class="mt-12 divide-y divide-line border-t border-b border-line">
      {
        references.map((ref) => (
          <div class="grid gap-2 py-6 sm:grid-cols-[1fr_auto] sm:items-center sm:gap-6">
            <div>
              <h3 class="font-display text-lg font-semibold text-navy-800">
                {ref.title} <span class="text-slate-600">— {ref.location}</span>
              </h3>
              <p class="mt-1 text-sm text-slate-600">{ref.detail}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
