---
import { references } from '../content/site';
---

<section id="referenzen" class="scroll-mt-24 bg-fog-50 pt-24 pb-20 sm:pt-28 sm:pb-28">
  <div class="mx-auto max-w-6xl px-6">
    <p class="flex items-center gap-3 font-mono text-xs uppercase tracking-[0.14em] text-slate-600">
      <span class="inline-block h-px w-6 bg-copper-500"></span>
      Referenzen
    </p>
    <h1 class="mt-4 text-balance break-words font-display text-3xl font-bold leading-tight text-navy-800 sm:text-4xl">
      Unsere Referenzen
    </h1>

    <div class="mt-12 divide-y divide-line border-t border-b border-line">
      {
        references.map((ref) => (
          <div class="grid gap-2 py-6 sm:grid-cols-[1fr_auto] sm:items-center sm:gap-6">
            <div>
              <h3 class="font-display text-lg font-semibold text-navy-800">
                {ref.title} <span class="text-slate-600">— {ref.location}</span>
              </h3>
              <p class="mt-1 text-sm text-slate-600">{ref.detail}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
