---
import { about, customers, values } from '../content/site';
---

<section id="ueber-uns" class="scroll-mt-24 bg-paper py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <p class="flex items-center gap-3 font-mono text-xs uppercase tracking-[0.14em] text-slate-600">
      <span class="inline-block h-px w-6 bg-copper-500"></span>
      {about.eyebrow}
    </p>

    <div class="mt-10 grid gap-12 sm:grid-cols-2 lg:gap-x-20 lg:gap-y-16">
      <div>
        <h2 class="font-mono text-xs uppercase tracking-[0.14em] text-slate-600">
          {about.headline}
        </h2>
        <p class="mt-5 text-justify text-base leading-relaxed text-slate-600">
          {about.lead}
        </p>
      </div>

      <div>
        <h3 class="font-mono text-xs uppercase tracking-[0.14em] text-slate-600">
          {about.whatWeDo.headline}
        </h3>
        <p class="mt-5 text-justify text-base leading-relaxed text-slate-600">
          {about.whatWeDo.text}
        </p>
      </div>

      <div>
        <h3 class="font-mono text-xs uppercase tracking-[0.14em] text-slate-600">
          {customers.headline}
        </h3>
        <ul class="mt-5 space-y-3">
          {
            customers.items.map((item) => (
              <li class="text-base font-semibold text-navy-800">{item}</li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3 class="font-mono text-xs uppercase tracking-[0.14em] text-slate-600">
          {values.headline}
        </h3>
        <ul class="mt-5 space-y-3">
          {
            values.items.map((item) => (
              <li class="text-base font-semibold text-navy-800">{item}</li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
