---
import { about, customers, values } from '../content/site';
---

<section id="ueber-uns" class="scroll-mt-24 bg-paper py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="grid gap-12 lg:grid-cols-[minmax(0,26rem)_1fr] lg:gap-20">
      <div>
        <h2 class="text-balance break-words font-display text-3xl font-bold leading-tight text-navy-800 sm:text-4xl">
          {about.headline}
        </h2>
        <p class="mt-5 text-base leading-relaxed text-slate-600">
          {about.lead}
        </p>
      </div>

      <div class="space-y-10">
        <div>
          <h3 class="font-display text-lg font-semibold text-navy-800">
            {about.whatWeDo.headline}
          </h3>
          <p class="mt-3 max-w-2xl text-base leading-relaxed text-slate-600">
            {about.whatWeDo.text}
          </p>
        </div>

        <div>
          <h3 class="font-display text-lg font-semibold text-navy-800">
            {about.scope.headline}
          </h3>
          <ul class="mt-4 space-y-3">
            {
              about.scope.items.map((item) => (
                <li class="flex gap-3 border-t border-line pt-3 text-base text-slate-600 first:border-t-0 first:pt-0">
                  <span class="mt-2 h-1.5 w-1.5 flex-none rounded-full bg-copper-500" />
                  {item}
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>

    <div class="mt-20 grid gap-12 border-t border-line pt-16 lg:grid-cols-2 lg:gap-20">
      <div>
        <h3 class="font-mono text-xs uppercase tracking-[0.14em] text-slate-600">
          {customers.headline}
        </h3>
        <ul class="mt-5 flex flex-wrap gap-x-8 gap-y-3">
          {
            customers.items.map((item) => (
              <li class="font-display text-lg font-semibold text-navy-800">{item}</li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3 class="font-mono text-xs uppercase tracking-[0.14em] text-slate-600">
          {values.headline}
        </h3>
        <ul class="mt-5 grid gap-x-8 gap-y-4 sm:grid-cols-2">
          {
            values.items.map((item) => (
              <li class="text-base font-semibold text-navy-800">{item}</li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
