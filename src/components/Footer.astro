---
import { navigation } from '../content/navigation';
import { hasOptionalServices } from '../content/consent';

const year = new Date().getFullYear();
const [homeItem, ...restItems] = navigation;
---

<footer class="border-t border-line bg-navy-900 text-slate-300">
  <div class="mx-auto max-w-6xl px-6 py-7">
    <div class="flex flex-col gap-6 md:flex-row md:items-start md:justify-between">
      <nav class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm">
        <a href={homeItem.href} aria-label={homeItem.label} class="hover:text-fog-50">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path
              d="M3 11.5L12 4l9 7.5M5.5 9.5V20a1 1 0 0 0 1 1h11a1 1 0 0 0 1-1V9.5M9.5 21v-6h5v6"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </a>
        {restItems.map((item) => <a href={item.href} class="hover:text-fog-50">{item.label}</a>)}
      </nav>
    </div>

    <div class="mt-6 flex flex-col gap-3 border-t border-white/10 pt-5 text-xs sm:flex-row sm:items-center sm:justify-between">
      <p>&copy; {year} SG Technik GmbH. Alle Rechte vorbehalten.</p>
      <div class="flex flex-wrap gap-x-5 gap-y-2">
        <a href="/impressum" class="hover:text-fog-50">Impressum</a>
        <a href="/datenschutz" class="hover:text-fog-50">Datenschutz</a>
        <a href="/cookie-richtlinie" class="hover:text-fog-50">Cookie-Richtlinie</a>
        {/* Nur relevant, sobald einwilligungspflichtige Dienste existieren: öffnet den Consent-Dialog. */}
        {
          hasOptionalServices && (
            <button
              type="button"
              data-consent-open
              class="text-left underline-offset-2 hover:text-fog-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-copper-500"
            >
              Cookie-Einstellungen
            </button>
          )
        }
      </div>
    </div>
  </div>
</footer>
