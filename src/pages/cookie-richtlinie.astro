---
import BaseLayout from '../layouts/BaseLayout.astro';
import { consentCategories, hasOptionalServices, consentMaxAgeMonths } from '../content/consent';
---

<BaseLayout
  title="Cookie-Richtlinie — SG Technik GmbH"
  description="Übersicht über die auf dieser Website eingesetzten Cookies und Speichertechnologien sowie die Einwilligungs-Kategorien."
>
  <section class="bg-paper pt-24 pb-20 sm:pt-28 sm:pb-28">
    <div class="mx-auto max-w-3xl px-6">
      <p class="flex items-center gap-3 font-mono text-xs uppercase tracking-[0.14em] text-slate-600">
        <span class="inline-block h-px w-6 bg-copper-500"></span>
        Datenschutz
      </p>
      <h1 class="mt-4 text-balance break-words font-display text-3xl font-bold leading-tight text-navy-800 sm:text-4xl">
        Cookie-Richtlinie
      </h1>

      <div class="mt-12 space-y-10 text-sm leading-relaxed text-slate-600">
        <div>
          <h2 class="font-display text-lg font-semibold text-navy-800">Was sind Cookies &amp; ähnliche Technologien?</h2>
          <p class="mt-2">
            Als „Cookies" bezeichnet man kleine Textdateien, die auf Ihrem Endgerät gespeichert werden.
            Vergleichbar wirkt der lokale Speicher Ihres Browsers (technisch „localStorage" genannt). Diese
            Website verwendet solche Technologien so sparsam wie möglich: Ohne Ihre Einwilligung wird
            ausschließlich das gespeichert, was für den Betrieb technisch notwendig ist.
          </p>
          <p class="mt-2">
            <strong class="font-semibold text-navy-800">Aktueller Stand:</strong> Es werden derzeit keine
            Analyse-, Statistik- oder Marketing-Dienste eingesetzt. Es findet kein Tracking statt. Die
            unten aufgeführten optionalen Kategorien sind vorbereitet und werden erst dann aktiv, wenn ein
            entsprechender Dienst ergänzt wird — und auch dann ausschließlich nach Ihrer Einwilligung.
          </p>
        </div>

        {
          consentCategories.map((cat) => (
            <div>
              <h2 class="flex flex-wrap items-center gap-3 font-display text-lg font-semibold text-navy-800">
                {cat.label}
                <span class="font-mono text-xs uppercase tracking-[0.1em] text-slate-600">
                  {cat.required ? 'Immer aktiv' : 'Einwilligung erforderlich'}
                </span>
              </h2>
              <p class="mt-2">{cat.description}</p>

              {cat.services.length > 0 ? (
                <ul class="mt-4 divide-y divide-line border-t border-b border-line">
                  {cat.services.map((service) => (
                    <li class="py-4">
                      <p class="font-semibold text-navy-800">{service.name}</p>
                      <dl class="mt-2 space-y-1">
                        <div class="grid gap-1 sm:grid-cols-[8rem_1fr] sm:gap-4">
                          <dt class="font-mono text-xs uppercase tracking-[0.1em] text-slate-600">Anbieter</dt>
                          <dd class="min-w-0 break-words text-navy-900">{service.provider}</dd>
                        </div>
                        <div class="grid gap-1 sm:grid-cols-[8rem_1fr] sm:gap-4">
                          <dt class="font-mono text-xs uppercase tracking-[0.1em] text-slate-600">Zweck</dt>
                          <dd class="min-w-0 break-words text-navy-900">{service.purpose}</dd>
                        </div>
                        <div class="grid gap-1 sm:grid-cols-[8rem_1fr] sm:gap-4">
                          <dt class="font-mono text-xs uppercase tracking-[0.1em] text-slate-600">Speicherung</dt>
                          <dd class="min-w-0 break-words text-navy-900">{service.cookies}</dd>
                        </div>
                        {service.privacyUrl && (
                          <div class="grid gap-1 sm:grid-cols-[8rem_1fr] sm:gap-4">
                            <dt class="font-mono text-xs uppercase tracking-[0.1em] text-slate-600">Datenschutz</dt>
                            <dd class="min-w-0 break-words">
                              <a
                                href={service.privacyUrl}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-navy-800 underline underline-offset-2 hover:text-copper-600"
                              >
                                {service.privacyUrl}
                              </a>
                            </dd>
                          </div>
                        )}
                      </dl>
                    </li>
                  ))}
                </ul>
              ) : (
                <p class="mt-3 italic text-slate-600">Derzeit sind in dieser Kategorie keine Dienste im Einsatz.</p>
              )}
            </div>
          ))
        }

        {
          hasOptionalServices ? (
            <div>
              <h2 class="font-display text-lg font-semibold text-navy-800">Einwilligung ändern oder widerrufen</h2>
              <p class="mt-2">
                Sie können Ihre Auswahl jederzeit anpassen oder vollständig widerrufen — über den Link{' '}
                <button
                  type="button"
                  data-consent-open
                  class="text-navy-800 underline underline-offset-2 transition-colors hover:text-copper-600 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-copper-500"
                >
                  Cookie-Einstellungen
                </button>{' '}
                (auch dauerhaft im Seitenfuß erreichbar). Ein Widerruf wirkt für die Zukunft und lässt die
                Rechtmäßigkeit der bis dahin erfolgten Verarbeitung unberührt.
              </p>
              <p class="mt-2">
                Ihre Entscheidung wird lokal in Ihrem Browser gespeichert (im lokalen Speicher, Eintrag
                „sg-consent") und nicht an unsere Server übertragen. Löschen Sie die Websitedaten Ihres
                Browsers, erscheint der Einwilligungs-Hinweis erneut.
              </p>
            </div>
          ) : (
            <div>
              <h2 class="font-display text-lg font-semibold text-navy-800">Speicherung verwalten</h2>
              <p class="mt-2">
                Derzeit wird ausschließlich technisch notwendige Speicherung verwendet; es gibt keine
                einwilligungspflichtigen Dienste, für die eine Einwilligung erteilt oder widerrufen werden
                müsste. Ihre Kenntnisnahme des Hinweises wird lokal in Ihrem Browser gespeichert (im lokalen
                Speicher, Eintrag „sg-consent") und nicht an unsere Server übertragen.
              </p>
              <p class="mt-2">
                Der Eintrag läuft nach {consentMaxAgeMonths} Monaten automatisch ab; danach erscheint der
                Hinweis erneut. Sie können ihn außerdem jederzeit über die Website- bzw. Cookie-Einstellungen
                Ihres Browsers löschen.
              </p>
            </div>
          )
        }

        <div>
          <h2 class="font-display text-lg font-semibold text-navy-800">Weitere Informationen</h2>
          <p class="mt-2">
            Details zur Verarbeitung personenbezogener Daten finden Sie in unserer{' '}
            <a href="/datenschutz" class="text-navy-800 underline underline-offset-2 hover:text-copper-600">
              Datenschutzerklärung</a>. Angaben zum Verantwortlichen enthält das{' '}
            <a href="/impressum" class="text-navy-800 underline underline-offset-2 hover:text-copper-600">
              Impressum</a>.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
