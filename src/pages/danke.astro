---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Danke — SG Technik GmbH"
  description="Ihre Nachricht wurde übermittelt."
>
  <section class="bg-paper pt-24 pb-20 sm:pt-28 sm:pb-28">
    <div class="mx-auto max-w-2xl px-6 text-center">
      <p class="flex items-center justify-center gap-3 font-mono text-xs uppercase tracking-[0.14em] text-slate-600">
        <span class="inline-block h-px w-6 bg-copper-500"></span>
        Danke
      </p>
      <h1 class="mt-4 text-balance break-words font-display text-3xl font-bold leading-tight text-navy-800 sm:text-4xl">
        Ihre Nachricht ist bei uns eingegangen.
      </h1>
      <p class="mt-5 text-base leading-relaxed text-slate-600">
        Wir melden uns so rasch wie möglich bei Ihnen zurück.
      </p>
      <a
        href="/"
        class="mt-10 inline-block rounded-sm border border-slate-300 px-6 py-3.5 text-center font-body text-sm font-semibold text-navy-800 transition-colors hover:border-navy-800"
      >
        Zurück zur Startseite
      </a>
    </div>
  </section>
</BaseLayout>
